# LOCAL — development only (copy to .env.local, gitignored)
# Loaded automatically by: npm run dev

# =============================================================================
# Clerk — development instance (immense-sawfish-81)
# https://dashboard.clerk.com/last-active?path=api-keys
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY_DEV=
CLERK_SECRET_KEY_DEV=

# Optional: prod keys for reference (not used when *_DEV is set)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY_PROD=
CLERK_SECRET_KEY_PROD=

CLERK_WEBHOOK_SIGNING_SECRET=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding/consent
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/consent

# Do NOT set NEXT_PUBLIC_CLERK_PROXY_URL for pk_test_ local dev

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DIDIT
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
DIDIT_WEBHOOK_SECRET_PREVIOUS=
NEXT_PUBLIC_DIDIT_SDK_URL=

# App — must match npm run dev port
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Optional: show dev theme switcher on Vercel preview (production NODE_ENV)
# NEXT_PUBLIC_DEV_THEME_SWITCHER=true

# Temporary: public palette preview in landing header for external color QA (redeploy after change)
# NEXT_PUBLIC_THEME_PREVIEW_PUBLIC=true
ALLOW_DEV_AUTH_BYPASS=true

AUDIT_ENCRYPTION_KEY=
