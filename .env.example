# Copy to `.env` for local dev and Vercel bulk import (gitignored). `.env.local` is optional.

# =============================================================================
# Clerk — dual keys (recommended local setup)
# =============================================================================
# Keep BOTH dev and prod keys in `.env`. `npm run dev` auto-selects *_DEV;
# production builds / Vercel use *_PROD (or legacy single keys below).
#
# Development instance **immense-sawfish-81** — Dashboard → Development → API Keys:
#   https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY_DEV=
CLERK_SECRET_KEY_DEV=

# Production (visual-era.com) — Dashboard → Production → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY_PROD=
CLERK_SECRET_KEY_PROD=

# Legacy single-key names (optional — still supported for Vercel Production import)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...

# Clerk Dashboard → Webhooks → signing secret (POST /api/webhooks/clerk)
CLERK_WEBHOOK_SIGNING_SECRET=

# pk_live_ / production only — same-origin /__clerk on https://visual-era.com
# NEXT_PUBLIC_CLERK_PROXY_URL=https://visual-era.com/__clerk
# NEXT_PUBLIC_CLERK_FORCE_PROXY=true
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding/consent
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/consent

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional legacy/public naming compatibility
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Required server-only key (never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=

# DIDIT
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
DIDIT_WEBHOOK_SECRET_PREVIOUS=
NEXT_PUBLIC_DIDIT_SDK_URL=


# App
# Local development URL (must match `npm run dev` port 3001)
# In Vercel production, set this to https://visual-era.com
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Development only — never set in Vercel production
ALLOW_DEV_AUTH_BYPASS=true

# Optional — 32+ char key for audit metadata encryption (preferred over service-role fallback)
AUDIT_ENCRYPTION_KEY=
