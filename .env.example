# Visual Era environment templates
#
# Recommended: two profile files (no manual key swapping)
#   cp .env.dev.example  .env.dev   →  npm run dev
#   cp .env.prod.example .env.prod  →  npm run build
#
# Legacy: single .env still works (with-env falls back if .env.dev is missing)
#   cp .env.dev.example .env
#
# Migrate existing .env:
#   ./scripts/split-env-from-legacy.sh

# See committed templates for full key lists:
#   .env.dev.example  — localhost, pk_test_ / *_DEV, ALLOW_DEV_AUTH_BYPASS
#   .env.prod.example — visual-era.com, pk_live_ / *_PROD, Clerk proxy
