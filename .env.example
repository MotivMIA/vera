# Visual Era environment templates
#
# Recommended (Next.js native — no wrapper scripts):
#   cp .env.local.example .env.local
#   cp .env.production.local.example .env.production.local
#   npm run dev    → loads .env.local automatically
#   npm run build  → loads .env.production.local automatically
#
# Migrate from .env.dev / .env.prod:
#   npm run env:migrate
#
# Legacy single file still works:
#   cp .env.local.example .env
