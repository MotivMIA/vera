# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Frontend API proxy (required in production when using clerkMiddleware frontendApiProxy)
# Example production: https://visual-era.vercel.app/__clerk
NEXT_PUBLIC_CLERK_PROXY_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/verify-identity
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/verify-identity

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional legacy/public naming compatibility
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Required server-only key (never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=

# DIDIT
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
NEXT_PUBLIC_DIDIT_SDK_URL=

# Jotform (optional legacy integration)
JOTFORM_API_KEY=
JOTFORM_FORM_URL=
JOTFORM_CLIENT_AGREEMENT_URL=
JOTFORM_CONTENT_RELEASE_URL=

# App
# Local development URL (example: localhost:3001)
# In Vercel production, set this to your public app URL, e.g. https://visual-era.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3001
