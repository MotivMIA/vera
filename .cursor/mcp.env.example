# Copy to mcp.env (gitignored). Used by ops scripts and Cursor MCP (GitHub header).
# Never commit mcp.env.

# GitHub MCP — run ./scripts/setup-cursor-mcp.sh to sync from `gh auth token`
GITHUB_PERSONAL_ACCESS_TOKEN=

# Cloudflare — zone-scoped token (DNS Edit) for visual-era.com only
CLOUDFLARE_API_TOKEN=
# Optional; auto-resolved if omitted
CLOUDFLARE_ZONE_ID=

# Vercel — optional; invalid tokens break `vercel` CLI (OAuth preferred locally)
VERCEL_TOKEN=

# Supabase MCP / management API (project-scoped)
SUPABASE_ACCESS_TOKEN=

# Resend — domains read + send
RESEND_API_KEY=
