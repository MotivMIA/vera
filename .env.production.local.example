# Local production builds — copy to .env.production.local (gitignored)
# Next.js loads this for npm run build / npm run start

# =============================================================================
# Clerk — production (visual-era.com)
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY_PROD=
CLERK_SECRET_KEY_PROD=

# Optional legacy single-key names (Vercel import compatibility)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

CLERK_WEBHOOK_SIGNING_SECRET=

# Same-origin proxy on production custom domain
# NEXT_PUBLIC_CLERK_PROXY_URL=https://visual-era.com/__clerk
# NEXT_PUBLIC_CLERK_FORCE_PROXY=true

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding/consent
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/consent

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DIDIT
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
DIDIT_WEBHOOK_SECRET_PREVIOUS=
NEXT_PUBLIC_DIDIT_SDK_URL=

NEXT_PUBLIC_SITE_URL=https://visual-era.com

# Never set ALLOW_DEV_AUTH_BYPASS in production

AUDIT_ENCRYPTION_KEY=
